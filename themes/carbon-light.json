
{
  "name": "Carbon Light",
  "type": "light",
  "colors": {
   "focusBorder": "#ffffff00",
   "foreground": "#000000",
   "editor.background": "#FFFFFF",
   "scrollbar.shadow": "#ffffff",
   "activityBar.border": "#ffffff",
   "activityBar.background": "#ffffff",
   "activityBar.foreground": "#000000",
   "activityBarBadge.background": "#d73a49",
   "statusBar.border": "#ffffff",
   "statusBar.background": "#ffffff",
   "statusBar.foreground": "#000000",
   "statusBar.noFolderBackground": "#ffffff",
   "statusBar.noFolderForeground": "#000000",
   "statusBar.debuggingBackground": "#ffffff",
   "statusBar.debuggingForeground": "#000000",
   "editorGroup.border": "#ffffff",
   "editorGroupHeader.tabsBackground": "#ffffff",
   "editorGroupHeader.noTabsBackground": "#ffffff",
   "editorGroupHeader.tabsBorder": "#ffffff",
   "tab.activeBackground": "#ffffff",
   "tab.inactiveBackground": "#ffffff",
   "tab.border": "#ffffff",
   "tab.activeBorder": "#d73a49",
   "sideBar.border": "#ffffff",
   "sideBar.background": "#ffffff",
   "sideBar.foreground": "#000000",
   "sideBarSectionHeader.background": "#ffffff",
   "list.highlightForeground": "#d73a49",
   "list.activeSelectionBackground": "#eeeeee",
   "list.activeSelectionForeground": "#d73a49",
   "list.inactiveSelectionBackground": "#eeeeee",
   "list.inactiveSelectionForeground": "#d73a49",
   "list.hoverBackground": "#eeeeee",
   "list.hoverForeground": "#d73a49",
   "list.focusBackground": "#eeeeee",
   "list.focusForeground": "#d73a49",
   "editor.lineHighlightBackground": "#fffbdf",
   "editor.lineHighlightBorder": "#fffbdf",
   "editorLineNumber.foreground": "#babbbc",
   "editorLineNumber.activeForeground": "#000000",
   "editor.selectionBackground": "#fed442",
   "input.border": "#b2b2b2",
   "input.background": "#ffffff",
   "inputOption.activeBorder": "#000000",
   "inputOption.activeForeground": "#000000",
   "dropdown.border": "#b2b2b2",
   "dropdown.background": "#ffffff",
   "dropdown.listBackground": "#ffffff",
   "notificationCenter.border": "#ffffff",
   "notificationCenterHeader.background": "#ffffff",
   "notificationToast.border": "#ffffff",
   "notifications.background": "#ffffff",
   "notifications.border": "#ffffff",
   "button.background": "#d73a49",
   "button.foreground": "#ffffff",
   "titleBar.border": "#ffffff",
   "titleBar.activeBackground": "#ffffff",
   "titleBar.activeForeground": "#000000",
   "titleBar.inactiveBackground": "#ffffff",
   "titleBar.inactiveForeground": "#000000",
   "editorWidget.background": "#ffffff",
   "editorWidget.border": "#000000",
   "editorSuggestWidget.highlightForeground": "#d73a49",
   "editorSuggestWidget.selectedBackground": "#f0f0f0",
   "panel.border": "#ffffff"
  },
  "tokenColors": [
    {
      "name": "Comment — Código comentado (gris claro, cursiva)",
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "string.comment"
      ],
      "settings": {
        "foreground": "#5D6976",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Constant — Constantes y variables de lenguaje (#6a8734)",
      "scope": [
        "constant",
        "entity.name.constant",
        "variable.other.constant",
        "variable.language"
      ],
      "settings": {
        "foreground": "#171717"
      }
    },
    {
      "name": "Numeric — Números y valores numéricos (#009688)",
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float",
        "constant.numeric.hex",
        "constant.numeric.octal",
        "constant.numeric.decimal"
      ],
      "settings": {
        "foreground": "#C97B61"
      }
    },
    {
      "name": "Boolean & Null — true, false, null (#009688)",
      "scope": [
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined",
        "constant.language.none"
      ],
      "settings": {
        "foreground": "#C97B61"
      }
    },
    {
      "name": "Clojure workaround; don't highlight these separately from their enclosing scope",
      "scope": [
        "keyword.operator.symbole",
        "keyword.other.mark"
      ],
      "settings": {
        "foreground": "#3D3D3D"
      }
    },
    {
      "name": "Entity — Clases, tipos, nombres de módulos (#F5CBA7)",
      "scope": [
        "entity",
        "entity.name",
        "entity.name.class",
        "entity.name.type",
        "entity.name.namespace",
        "entity.name.module"
      ],
      "settings": {
        "foreground": "#2C3846"
      }
    },
    {
      "name": "Function parameter — Parámetros de función (#9876AA)",
      "scope": [
        "variable.parameter.function",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#171717"
      }
    },
    {
      "name": "HTML / XML Tags — Etiquetas HTML/XML (#C56C86)",
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#ec003f"
      }
    },
    {
      "name": "HTML / XML Attributes — Atributos HTML (#73A7A7)",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#16a34a"
      }
    },
    {
      "name": "Keyword — Palabras clave (if, else, return, etc) (#AF00FF)",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.as"
      ],
      "settings": {
        "foreground": "#ec003f"
      }
    },
    {
      "name": "Keyword Operator — Operadores (->, =>, ::, etc) (#D63079)",
      "scope": [
        "keyword.operator",
        "punctuation.accessor",
        "keyword.operator.arrow"
      ],
      "settings": {
        "foreground": "#020617"
      }
    },
    {
      "name": "Storage — Declaraciones de tipo (var, let, function, class) (#0000FF)",
      "scope": [
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#ec003f"
      }
    },
    {
      "name": "Storage — Java imports (plain)",
      "scope": [
        "storage.modifier.package",
        "storage.modifier.import",
        "storage.type.java"
      ],
      "settings": {
        "foreground": "#3D3D3D"
      }
    },
    {
      "name": "String — Cadenas de texto (#A31515)",
      "scope": [
        "punctuation.definition.string",
        "string punctuation.section.embedded source"
      ],
      "settings": {
        "foreground": "#ec003f"
      }
    },
    {
      "name": "Ada workaround; don't highlight imports as strings",
      "scope": [
        "string.unquoted.import.ada"
      ],
      "settings": {}
    },
    {
      "name": "Template literal / interpolation — Plantillas (#A31515)",
      "scope": [
        "string.template",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#73A7A7"
      }
    },
    {
      "name": "Support — Funciones y tipos built-in (#0F9090)",
      "scope": [
        "support",
        "support.function",
        "support.class",
        "support.type",
        "support.constant"
      ],
      "settings": {
        "foreground": "#4f46e5"
      }
    },
    {
      "name": "CSS Property name — Nombres de propiedades CSS (#CDD3D3)",
      "scope": [
        "meta.property-name",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#6B7280"
      }
    },
    {
      "name": "CSS Property value — Valores de propiedades CSS (#0AADAD)",
      "scope": [
        "meta.property-value",
        "support.constant.property-value"
      ],
      "settings": {
        "foreground": "#F2C4B3"
      }
    },
    {
      "name": "Variable — Variables generales (#7B3F00)",
      "scope": [
        "variable"
      ],
      "settings": {
        "foreground": "#B87EA2"
      }
    },
    {
      "name": "Variable — Otras variables (#7B3F00)",
      "scope": [
        "variable.other",
        "variable.other.readwrite",
        "variable.other.php",
        "variable.other.property"
      ],
      "settings": {
        "foreground": "#16a34a"
      }
    },
    {
      "name": "PHP $this / self / language vars — Variables especiales PHP (#7B3F00)",
      "scope": [
        "variable.language.this",
        "variable.language.self",
        "variable.language.parent",
        "variable.language.static"
      ],
      "settings": {
        "foreground": "#ec003f",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Function & Method names — Nombres de funciones (#E8602A)",
      "scope": [
        "entity.name.function",
        "entity.name.method",
        "meta.function-call entity.name.function",
        "meta.function-call support.function"
      ],
      "settings": {
        "foreground": "#1d4ed8"
      }
    },
    {
      "name": "Invalid — Código roto o inválido (#D4224A)",
      "scope": [
        "invalid.broken",
        "invalid.deprecated",
        "invalid.illegal",
        "invalid.unimplemented"
      ],
      "settings": {
        "foreground": "#E8859A",
        "fontStyle": "bold italic underline"
      }
    },
    {
      "name": "Carriage Return — Retorno de carro (#D4224A)",
      "scope": [
        "carriage-return"
      ],
      "settings": {
        "fontStyle": "italic underline",
        "foreground": "#E8859A"
      }
    },
    {
      "name": "Message error — Mensajes de error (#D4224A)",
      "scope": [
        "message.error"
      ],
      "settings": {
        "foreground": "#E8859A"
      }
    },
    {
      "name": "String embedded-source — Código embebido en strings",
      "scope": [
        "string source"
      ],
      "settings": {
        "foreground": "#2C3846"
      }
    },
    {
      "name": "String variable — Variables en strings (#0F9090)",
      "scope": [
        "string variable"
      ],
      "settings": {
        "foreground": "#5C9A9A"
      }
    },
    {
      "name": "Regexp — Expresiones regulares (#0AADAD)",
      "scope": [
        "source.regexp",
        "string.regexp"
      ],
      "settings": {
        "foreground": "#F2C4B3"
      }
    },
    {
      "name": "Regexp special — Caracteres especiales en regex (#0AADAD)",
      "scope": [
        "string.regexp.character-class",
        "string.regexp constant.character.escape",
        "string.regexp source.ruby.embedded",
        "string.regexp string.regexp.arbitrary-repitition"
      ],
      "settings": {
        "foreground": "#F2C4B3"
      }
    },
    {
      "name": "Regexp escape bold — Secuencias de escape en regex (#A5C25C)",
      "scope": [
        "string.regexp constant.character.escape"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#A5C25C"
      }
    },
    {
      "name": "Support.constant — Constantes de soporte (#0F9090)",
      "scope": [
        "support.constant"
      ],
      "settings": {
        "foreground": "#5C9A9A"
      }
    },
    {
      "name": "Support.variable — Variables de soporte (#0F9090)",
      "scope": [
        "support.variable"
      ],
      "settings": {
        "foreground": "#5C9A9A"
      }
    },
    {
      "name": "Meta module-reference — Referencias de módulos (#0F9090)",
      "scope": [
        "meta.module-reference"
      ],
      "settings": {
        "foreground": "#5C9A9A"
      }
    },
    {
      "name": "Markup list — Listas en Markdown (#7B3FC4)",
      "scope": [
        "markup.list"
      ],
      "settings": {
        "foreground": "#171717"
      }
    },
    {
      "name": "Markup heading — Encabezados en Markdown (#F5CBA7)",
      "scope": [
        "markup.heading",
        "markup.heading entity.name"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#374151"
      }
    },
    {
      "name": "Markup quote — Citas en Markdown (#57A464)",
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#57A464"
      }
    },
    {
      "name": "Markup italic — Texto italic en Markdown",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#374151"
      }
    },
    {
      "name": "Markup bold — Texto bold en Markdown",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#374151"
      }
    },
    {
      "name": "Markup raw — Código inline en Markdown (#0F9090)",
      "scope": [
        "markup.raw",
        "markup.inline.raw"
      ],
      "settings": {
        "foreground": "#5C9A9A"
      }
