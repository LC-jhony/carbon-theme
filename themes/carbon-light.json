      }
    },
    {
      "name": "Sublimelinter error — Errores de linter (#D4224A)",
      "scope": [
        "sublimelinter.mark.error"
      ],
      "settings": {
        "foreground": "#E8859A"
      }
    },
    {
      "name": "Sublimelinter warning — Warnings de linter (#FFAE8F)",
      "scope": [
        "sublimelinter.mark.warning"
      ],
      "settings": {
