    {
      "name": "Sublimelinter gutter — Marcas de linter (#8C9EAA)",
      "scope": [
        "sublimelinter.gutter-mark"
      ],
      "settings": {
        "foreground": "#5D6976"
      }
    },
    {
      "name": "Link — Enlaces (#1E5FAD)",
      "scope": [
        "constant.other.reference.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#5C9A9A",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Punctuation — Signos de puntuación (#3D3D3D)",
      "scope": [
        "punctuation",
        "punctuation.definition",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#3D3D3D"
      }
    },
    {
      "name": "Type annotation — Anotaciones de tipo (#171717)",
      "scope": [
        "entity.name.type",
        "support.type",
        "meta.type.annotation"
      ],
      "settings": {
        "foreground": "#111827"
      }
    },
    {
      "name": "Decorator / annotation — Decoradores (#C85C7A)",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "entity.name.function.decorator"
      ],
      "settings": {
        "foreground": "#C85C7A"
      }
    },
    {
      "name": "Operators & Assignment — Operadores (=, +, -, *, /, &&, ||, etc) (#D63079)",
      "scope": [
        "keyword.operator.assignment",
        "keyword.operator.arithmetic",
        "keyword.operator.logical",
        "keyword.operator.comparison",
        "keyword.operator.bitwise",
        "keyword.operator.increment",
        "keyword.operator.decrement",
        "keyword.operator.ternary",
        "keyword.operator.spread",
        "keyword.operator.nullish",
        "keyword.operator.optional",
        "keyword.operator.type",
        "punctuation.separator.key-value"
      ],
      "settings": {
        "foreground": "#ec003f"
      }
    },
    {
      "name": "PHP Open/Close Tags (Blade Embedded) — Tags PHP/Blade (#0F9090)",
      "scope": [
        "punctuation.section.embedded.begin.php",
        "punctuation.section.embedded.end.php",
        "meta.embedded.block.php punctuation.section.embedded",
        "punctuation.definition.tag.begin.blade",
        "punctuation.definition.tag.end.blade",
        "keyword.blade",
        "support.function.blade",
        "meta.tag.template.blade"
      ],
      "settings": {
        "foreground": "#1e293b"
      }
