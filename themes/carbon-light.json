      }
    },
    {
      "name": "Diff range — Rangos en diffs (#7B3FC4)",
      "scope": [
        "meta.diff.range"
      ],
      "settings": {
        "foreground": "#171717",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Diff header — Encabezados de diffs (#0F9090)",
      "scope": [
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#5C9A9A"
      }
    },
    {
      "name": "Meta separator — Separadores (#0F9090)",
      "scope": [
        "meta.separator"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#5C9A9A"
      }
    },
    {
      "name": "Output — Salida de consola (#0F9090)",
      "scope": [
        "meta.output"
      ],
      "settings": {
        "foreground": "#5C9A9A"
      }
    },
    {
      "name": "Bracket highlighter — Resaltado de brackets (#7B3FC4)",
      "scope": [
        "brackethighlighter.tag",
        "brackethighlighter.curly",
        "brackethighlighter.round",
        "brackethighlighter.square",
        "brackethighlighter.angle",
        "brackethighlighter.quote"
