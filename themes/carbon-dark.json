  "tokenColors": [
    {
      "name": "Comment — Código comentado (gris claro, cursiva)",
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "string.comment"
      ],
      "settings": {
        "foreground": "#5D6976",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Constant — Constantes y variables de lenguaje (#6a8734)",
      "scope": [
        "constant",
        "entity.name.constant",
        "variable.other.constant",
        "variable.language"
      ],
      "settings": {
        "foreground": "#A67DB8"
      }
    },
    {
      "name": "Numeric — Números y valores numéricos (#009688)",
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float",
        "constant.numeric.hex",
        "constant.numeric.octal",
        "constant.numeric.decimal"
      ],
      "settings": {
        "foreground": "#F2C4B3"
      }
    },
    {
      "name": "Boolean & Null — true, false, null (#009688)",
      "scope": [
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined",
        "constant.language.none"
      ],
      "settings": {
        "foreground": "#F2C4B3"
      }
    },
    {
      "name": "Clojure workaround; don't highlight these separately from their enclosing scope",
      "scope": [
        "keyword.operator.symbole",
        "keyword.other.mark"
      ],
      "settings": {
        "foreground": "#3D3D3D"
      }
    },
    {
      "name": "Entity — Clases, tipos, nombres de módulos (#F5CBA7)",
      "scope": [
        "entity",
        "entity.name",
        "entity.name.class",
        "entity.name.type",
        "entity.name.namespace",
        "entity.name.module"
      ],
      "settings": {
        "foreground": "#C9CCCD"
      }
    },
    {
      "name": "Function parameter — Parámetros de función (#9876AA)",
      "scope": [
        "variable.parameter.function",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#A67DB8"
      }
    },
    {
      "name": "HTML / XML Tags — Etiquetas HTML/XML (#C56C86)",
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#C56C86"
      }
    },
    {
      "name": "HTML / XML Attributes — Atributos HTML (#73A7A7)",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#eba48e"
      }
    },
    {
      "name": "Keyword — Palabras clave (if, else, return, etc) (#AF00FF)",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.as"
      ],
      "settings": {
        "foreground": "#C56C86"
      }
    },
    {
      "name": "Keyword Operator — Operadores (->, =>, ::, etc) (#D63079)",
      "scope": [
        "keyword.operator",
        "punctuation.accessor",
        "keyword.operator.arrow"
      ],
      "settings": {
        "foreground": "#9A3B56"
      }
    },
    {
      "name": "Storage — Declaraciones de tipo (var, let, function, class) (#0000FF)",
      "scope": [
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#9A3B56"
      }
    },
    {
      "name": "Storage — Java imports (plain)",
      "scope": [
        "storage.modifier.package",
        "storage.modifier.import",
        "storage.type.java"
      ],
      "settings": {
        "foreground": "#3D3D3D"
      }
    },
    {
      "name": "String — Cadenas de texto (#A31515)",
      "scope": [
        "string",
        "punctuation.definition.string",
        "string punctuation.section.embedded source"
      ],
      "settings": {
        "foreground": "#73A7A7"
      }
    },
    {
      "name": "Ada workaround; don't highlight imports as strings",
      "scope": [
        "string.unquoted.import.ada"
      ],
      "settings": {}
    },
    {
      "name": "Template literal / interpolation — Plantillas (#A31515)",
      "scope": [
        "string.template",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#73A7A7"
      }
    },
    {
