{
  "name": "Carbon dark",
  "type": "dark",
  "colors": {
    "focusBorder": "#171717",
    "foreground": "#e0e0e0",
    "editor.background": "#171717",
    "editor.foreground": "#e0e0e0",
    "scrollbar.shadow": "#000000",
    "activityBar.border": "#171717",
    "activityBar.background": "#171717",
    "activityBar.foreground": "#e0e0e0",
    "activityBarBadge.background": "#e74c3c",
    "statusBar.border": "#171717",
    "statusBar.background": "#1e1e1e",
    "statusBar.foreground": "#e0e0e0",
    "statusBar.noFolderBackground": "#1e1e1e",
    "statusBar.noFolderForeground": "#e0e0e0",
    "statusBar.debuggingBackground": "#1e1e1e",
    "statusBar.debuggingForeground": "#e0e0e0",
    "editorGroup.border": "#171717",
    "editorGroupHeader.tabsBackground": "#171717",
    "editorGroupHeader.noTabsBackground": "#171717",
    "editorGroupHeader.tabsBorder": "#171717",
    "tab.activeBackground": "#171717",
    "tab.inactiveBackground": "#1e1e1e",
    "tab.border": "#171717",
    "tab.activeBorder": "#171717",
    "sideBar.border": "#171717",
    "sideBar.background": "#171717",
    "sideBar.foreground": "#e0e0e0",
    "sideBarSectionHeader.background": "#1e1e1e",
    "list.highlightForeground": "#e74c3c",
    "list.activeSelectionBackground": "#2d2d2d",
    "list.activeSelectionForeground": "#e74c3c",
    "list.inactiveSelectionBackground": "#2d2d2d",
    "list.inactiveSelectionForeground": "#e74c3c",
    "list.hoverBackground": "#2d2d2d",
    "list.hoverForeground": "#e74c3c",
    "list.focusBackground": "#2d2d2d",
    "list.focusForeground": "#e74c3c",
    "editor.lineHighlightBackground": "#2a2a2a",
    "editor.lineHighlightBorder": "#171717",
    "editorLineNumber.foreground": "#555555",
    "editorLineNumber.activeForeground": "#e0e0e0",
    "editor.selectionBackground": "#3d5a80",
    "input.border": "#3d3d3d",
    "input.background": "#1e1e1e",
    "inputOption.activeBorder": "#e0e0e0",
    "inputOption.activeForeground": "#e0e0e0",
    "dropdown.border": "#3d3d3d",
    "dropdown.background": "#1e1e1e",
    "dropdown.listBackground": "#1e1e1e",
    "notificationCenter.border": "#2d2d2d",
    "notificationCenterHeader.background": "#1e1e1e",
    "notificationToast.border": "#2d2d2d",
    "notifications.background": "#1e1e1e",
    "notifications.border": "#2d2d2d",
    "button.background": "#e74c3c",
    "button.foreground": "#ffffff",
    "titleBar.border": "#171717",
    "titleBar.activeBackground": "#171717",
    "titleBar.activeForeground": "#e0e0e0",
    "titleBar.inactiveBackground": "#171717",
    "titleBar.inactiveForeground": "#888888",
    "editorWidget.background": "#1e1e1e",
    "editorWidget.border": "#171717",
    "editorSuggestWidget.highlightForeground": "#e74c3c",
    "editorSuggestWidget.selectedBackground": "#2d2d2d",
    "panel.border": "#171717"
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "string.comment"
      ],
      "settings": {
        "foreground": "#5D6976",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Constant & Language Variables",
      "scope": [
        "constant",
        "entity.name.constant",
        "variable.other.constant",
        "variable.language"
      ],
      "settings": {
        "foreground": "#9E74AE"
      }
    },
    {
      "name": "Numeric Values",
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float",
        "constant.numeric.hex",
        "constant.numeric.octal",
        "constant.numeric.decimal"
      ],
      "settings": {
        "foreground": "#F6BEAD"
      }
    },
    {
      "name": "Boolean & Null",
      "scope": [
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined",
        "constant.language.none"
      ],
      "settings": {
        "foreground": "#F6BEAD"
      }
    },
    {
      "name": "Clojure workaround",
      "scope": [
        "keyword.operator.symbole",
        "keyword.other.mark"
      ],
      "settings": {
        "foreground": "#3D3D3D"
      }
    },
    {
      "name": "Entity (Classes, Types, Modules)",
      "scope": [
        "entity",
        "entity.name",
        "entity.name.class",
        "entity.name.type",
        "entity.name.namespace",
        "entity.name.module"
      ],
      "settings": {
        "foreground": "#C8CCCD"
      }
    },
    {
      "name": "Function Parameter",
      "scope": [
        "variable.parameter.function",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#9E74AE"
      }
    },
    {
      "name": "HTML / XML Tags",
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#EB6689"
      }
    },
    {
      "name": "HTML / XML Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#F6BEAD"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.as"
      ],
      "settings": {
        "foreground": "#EB6689"
      }
    },
    {
      "name": "Keyword Operator",
      "scope": [
        "keyword.operator",
        "punctuation.accessor",
        "keyword.operator.arrow"
      ],
      "settings": {
        "foreground": "#9A3B56"
      }
    },
    {
      "name": "Storage (var, let, function, class)",
      "scope": [
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#9A3B56"
      }
    },
    {
      "name": "Storage — Java imports",
      "scope": [
        "storage.modifier.package",
        "storage.modifier.import",
        "storage.type.java"
      ],
      "settings": {
        "foreground": "#3D3D3D"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "punctuation.definition.string",
        "string punctuation.section.embedded source"
      ],
      "settings": {
        "foreground": "#73A7A7"
      }
    },
    {
      "name": "Ada workaround",
      "scope": [
        "string.unquoted.import.ada"
      ],
      "settings": {}
    },
    {
      "name": "Template Literal / Interpolation",
      "scope": [
        "string.template",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#73A7A7"
      }
    },
    {
      "name": "Support (Built-in functions and types)",
      "scope": [
        "support",
        "support.function",
        "support.class",
        "support.type",
        "support.constant"
      ],
      "settings": {
        "foreground": "#c9ccc3"
      }
    },
    {
      "name": "CSS Property Name",
      "scope": [
        "meta.property-name",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#CDD3D3"
      }
    },
    {
      "name": "CSS Property Value",
      "scope": [
        "meta.property-value",
        "support.constant.property-value"
      ],
      "settings": {
        "foreground": "#F6BEAD"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable"
      ],
      "settings": {
        "foreground": "#9E74AE"
      }
    },
    {
      "name": "Variable (Other)",
      "scope": [
        "variable.other",
        "variable.other.readwrite",
        "variable.other.php",
        "variable.other.property"
      ],
      "settings": {
        "foreground": "#9E74AE"
      }
    },
    {
      "name": "PHP Special Variables ($this, self)",
      "scope": [
        "variable.language.this",
        "variable.language.self",
        "variable.language.parent",
        "variable.language.static"
      ],
      "settings": {
        "foreground": "#f3999a",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Function & Method Names",
      "scope": [
        "entity.name.function",
        "entity.name.method",
        "meta.function-call entity.name.function",
        "meta.function-call support.function"
      ],
      "settings": {
        "foreground": "#FFB1A9"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid.broken",
        "invalid.deprecated",
        "invalid.illegal",
        "invalid.unimplemented"
      ],
      "settings": {
        "foreground": "#F44747",
        "fontStyle": "bold italic underline"
      }
    },
    {
      "name": "Carriage Return",
      "scope": [
        "carriage-return"
      ],
      "settings": {
        "fontStyle": "italic underline",
        "foreground": "#F44747"
      }
    },
    {
      "name": "Message Error",
      "scope": [
        "message.error"
      ],
      "settings": {
        "foreground": "#F44747"
      }
    },
    {
      "name": "String Embedded Source",
      "scope": [
        "string source"
      ],
      "settings": {
        "foreground": "#C8CCCD"
      }
    },
    {
      "name": "String Variable",
      "scope": [
        "string variable"
      ],
      "settings": {
        "foreground": "#5C9A9A"
      }
    },
    {
      "name": "Regexp",
      "scope": [
        "source.regexp",
        "string.regexp"
      ],
      "settings": {
        "foreground": "#F6BEAD"
      }
    },
    {
      "name": "Regexp Special Characters",
      "scope": [
        "string.regexp.character-class",
        "string.regexp constant.character.escape",
        "string.regexp source.ruby.embedded",
        "string.regexp string.regexp.arbitrary-repitition"
      ],
      "settings": {
        "foreground": "#F6BEAD"
      }
    },
    {
      "name": "Regexp Escape Bold",
      "scope": [
        "string.regexp constant.character.escape"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#A5C25C"
      }
    },
    {
      "name": "Support Constant",
      "scope": [
        "support.constant"
      ],
      "settings": {
        "foreground": "#5C9A9A"
      }
    },
    {
      "name": "Support Variable",
      "scope": [
        "support.variable"
      ],
      "settings": {
        "foreground": "#5C9A9A"
      }
    },
    {
      "name": "Meta Module-Reference",
      "scope": [
        "meta.module-reference"
      ],
      "settings": {
        "foreground": "#5C9A9A"
      }
    },
    {
      "name": "Markup List",
      "scope": [
        "markup.list"
      ],
      "settings": {
        "foreground": "#9E74AE"
      }
    },
    {
      "name": "Markup Heading",
      "scope": [
        "markup.heading",
        "markup.heading entity.name"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#C8CCCD"
      }
    },
    {
      "name": "Markup Quote",
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#57A464"
      }
    },
    {
      "name": "Markup Italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#C8CCCD"
      }
    },
    {
      "name": "Markup Bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#C8CCCD"
      }
    },
    {
      "name": "Markup Raw",
      "scope": [
        "markup.raw",
        "markup.inline.raw"
      ],
      "settings": {
        "foreground": "#5C9A9A"
      }
    },
    {
      "name": "Markup Deleted",
      "scope": [
        "markup.deleted",
        "meta.diff.header.from-file",
        "punctuation.definition.deleted"
      ],
      "settings": {
        "foreground": "#9A3B56"
      }
    },
    {
      "name": "Markup Inserted",
      "scope": [
        "markup.inserted",
        "meta.diff.header.to-file",
        "punctuation.definition.inserted"
      ],
      "settings": {
        "foreground": "#57A464"
      }
    },
    {
      "name": "Markup Changed",
      "scope": [
        "markup.changed",
        "punctuation.definition.changed"
      ],
      "settings": {
        "foreground": "#3D3D3D"
      }
    },
    {
      "name": "Markup Ignored / Untracked",
      "scope": [
        "markup.ignored",
        "markup.untracked"
      ],
      "settings": {
        "foreground": "#5D6976"
      }
    },
    {
      "name": "Diff Range",
      "scope": [
        "meta.diff.range"
      ],
      "settings": {
        "foreground": "#9E74AE",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Diff Header",
      "scope": [
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#5C9A9A"
      }
    },
    {
      "name": "Meta Separator",
      "scope": [
        "meta.separator"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#5C9A9A"
      }
    },
    {
      "name": "Output",
      "scope": [
        "meta.output"
      ],
      "settings": {
        "foreground": "#5C9A9A"
      }
    },
    {
      "name": "Bracket Highlighter",
      "scope": [
        "brackethighlighter.tag",
        "brackethighlighter.curly",
        "brackethighlighter.round",
        "brackethighlighter.square",
        "brackethighlighter.angle",
        "brackethighlighter.quote"
      ],
      "settings": {
        "foreground": "#9E74AE"
      }
    },
    {
      "name": "Bracket Highlighter Unmatched",
      "scope": [
        "brackethighlighter.unmatched"
      ],
      "settings": {
        "foreground": "#F44747"
      }
    },
    {
      "name": "Link",
      "scope": [
        "constant.other.reference.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#5C9A9A",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "punctuation.definition",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#c9ccc3"
      }
    },
    {
      "name": "Type Annotation",
      "scope": [
        "entity.name.type",
        "support.type",
        "meta.type.annotation"
      ],
      "settings": {
        "foreground": "#9E74AE"
      }
    },
    {
      "name": "Decorator / Annotation",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "entity.name.function.decorator"
      ],
      "settings": {
        "foreground": "#9A3B56"
      }
    },
    {
      "name": "Operators & Assignment",
      "scope": [
        "keyword.operator.assignment",
        "keyword.operator.arithmetic",
        "keyword.operator.logical",
        "keyword.operator.comparison",
        "keyword.operator.bitwise",
        "keyword.operator.increment",
        "keyword.operator.decrement",
        "keyword.operator.ternary",
        "keyword.operator.spread",
        "keyword.operator.nullish",
        "keyword.operator.optional",
        "keyword.operator.type",
        "punctuation.separator.key-value"
      ],
      "settings": {
        "foreground": "#9A3B56"
      }
    },
    {
      "name": "PHP Tags / Blade",
      "scope": [
        "punctuation.section.embedded.begin.php",
        "punctuation.section.embedded.end.php",
        "meta.embedded.block.php punctuation.section.embedded",
        "punctuation.definition.tag.begin.blade",
        "punctuation.definition.tag.end.blade",
        "keyword.blade",
        "support.function.blade",
        "meta.tag.template.blade"
      ],
      "settings": {
        "foreground": "#5C9A9A"
      }
    }
  ]
}